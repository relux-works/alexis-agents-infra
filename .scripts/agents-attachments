#!/usr/bin/env python3

import base64
import hashlib
import json
import mimetypes
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path
from typing import Callable, Optional, Tuple


MANIFEST_ENV = "AGENTS_ATTACHMENTS_MANIFEST"
DEFAULT_MANIFEST = ".temp/agents-attachments-manifest.json"
DEFAULT_OUT_DIR_NAME = "agents-attachments"
DEFAULT_IMAGE_STAGE_DIR = ".temp/image-intake"
DEFAULT_IMAGE_MAPPING_NAME = "image-stage-map.json"
DATA_URL_RE = re.compile(r"^data:(?P<mime>[^;]+);base64,(?P<data>.+)$", re.DOTALL)
IMAGE_NAME_RE = re.compile(r"<image\s+name=\[(?P<name>[^\]]+)\]>", re.IGNORECASE)
IMAGE_EXTENSIONS = {
    ".bmp",
    ".gif",
    ".heic",
    ".heif",
    ".jpeg",
    ".jpg",
    ".png",
    ".tif",
    ".tiff",
    ".webp",
}
HEIC_EXTENSIONS = {".heic", ".heif"}
SENSITIVE_REDACTIONS = [
    (re.compile(r"\b89\d{17,20}\b"), "[REDACTED_ICCID]"),
    (re.compile(r"\b\d{14,15}\b"), "[REDACTED_IMSI]"),
    (re.compile(r"(?i)\b(api[_-]?key|secret|token|password|passwd|pwd|qr)[=:][^\s/\\]+"), r"\1=[REDACTED_SECRET]"),
    (re.compile(r"\b[A-Fa-f0-9]{32,}\b"), "[REDACTED_HEX_SECRET]"),
    (re.compile(r"\b[A-Za-z0-9_-]{40,}\b"), "[REDACTED_KEYLIKE_SECRET]"),
]


def usage() -> int:
    print(
        "Usage:\n"
        "  agents-attachments list [--manifest PATH]\n"
        "  agents-attachments show <id-or-name> [--manifest PATH]\n"
        "  agents-attachments path <id-or-name> [--manifest PATH]\n"
        "  agents-attachments materialize [--thread-id ID] [--session PATH] [--out-dir DIR] [--manifest PATH]\n"
        "  agents-attachments stage-images [--manifest PATH] [--out-dir DIR] [--mapping PATH] [--all] <path-or-id-or-name>...",
        file=sys.stderr,
    )
    return 2


def resolve_manifest_path(argv: list[str]) -> tuple[Path, list[str]]:
    args = list(argv)
    manifest = None
    i = 0
    while i < len(args):
        arg = args[i]
        if arg == "--manifest":
            if i + 1 >= len(args):
                raise SystemExit("--manifest requires a path")
            manifest = args[i + 1]
            del args[i : i + 2]
            continue
        if arg.startswith("--manifest="):
            manifest = arg.split("=", 1)[1]
            del args[i]
            continue
        i += 1

    path = manifest or os.environ.get(MANIFEST_ENV) or DEFAULT_MANIFEST
    return Path(path), args


def load_attachments(path: Path) -> list[dict]:
    if not path.exists():
        raise SystemExit(f"manifest not found: {path}")

    with path.open("r", encoding="utf-8") as fh:
        data = json.load(fh)

    if isinstance(data, list):
        attachments = data
    elif isinstance(data, dict):
        attachments = data.get("attachments", [])
    else:
        raise SystemExit(f"unsupported manifest shape in {path}")

    if not isinstance(attachments, list):
        raise SystemExit(f"attachments field must be a list in {path}")

    result = []
    for item in attachments:
        if isinstance(item, dict):
            result.append(item)
    return result


def attachment_key(item: dict, key: str) -> str:
    value = item.get(key, "")
    return value if isinstance(value, str) else str(value)


def find_attachment(attachments: list[dict], needle: str) -> dict:
    matches = []
    for item in attachments:
        if attachment_key(item, "id") == needle:
            matches.append(item)
            continue
        if attachment_key(item, "name") == needle:
            matches.append(item)
            continue
        local_path = attachment_key(item, "local_path")
        if local_path and Path(local_path).name == needle:
            matches.append(item)

    if not matches:
        raise SystemExit(f"attachment not found: {needle}")
    if len(matches) > 1:
        raise SystemExit(f"attachment reference is ambiguous: {needle}")
    return matches[0]


def cmd_list(attachments: list[dict]) -> int:
    for item in attachments:
        print(
            "\t".join(
                [
                    attachment_key(item, "id"),
                    attachment_key(item, "name"),
                    attachment_key(item, "mime_type"),
                    attachment_key(item, "local_path"),
                ]
            )
        )
    return 0


def cmd_show(attachments: list[dict], needle: str) -> int:
    print(json.dumps(find_attachment(attachments, needle), indent=2, ensure_ascii=False))
    return 0


def cmd_path(attachments: list[dict], needle: str) -> int:
    item = find_attachment(attachments, needle)
    local_path = attachment_key(item, "local_path")
    if not local_path:
        raise SystemExit(f"attachment has no local_path: {needle}")
    print(local_path)
    return 0


def resolve_materialize_options(args: list[str], manifest_path: Path) -> Tuple[Optional[str], Optional[Path], Path]:
    thread_id = os.environ.get("CODEX_THREAD_ID")
    session_path = None
    out_dir = manifest_path.parent / DEFAULT_OUT_DIR_NAME
    i = 0

    while i < len(args):
        arg = args[i]
        if arg == "--thread-id":
            if i + 1 >= len(args):
                raise SystemExit("--thread-id requires a value")
            thread_id = args[i + 1]
            i += 2
            continue
        if arg.startswith("--thread-id="):
            thread_id = arg.split("=", 1)[1]
            i += 1
            continue
        if arg == "--session":
            if i + 1 >= len(args):
                raise SystemExit("--session requires a path")
            session_path = Path(args[i + 1]).expanduser()
            i += 2
            continue
        if arg.startswith("--session="):
            session_path = Path(arg.split("=", 1)[1]).expanduser()
            i += 1
            continue
        if arg == "--out-dir":
            if i + 1 >= len(args):
                raise SystemExit("--out-dir requires a path")
            out_dir = Path(args[i + 1]).expanduser()
            i += 2
            continue
        if arg.startswith("--out-dir="):
            out_dir = Path(arg.split("=", 1)[1]).expanduser()
            i += 1
            continue
        raise SystemExit(f"unknown option for materialize: {arg}")

    return thread_id, session_path, out_dir


def find_rollout_path(thread_id: str) -> Path:
    sessions_root = Path.home() / ".codex" / "sessions"
    if not sessions_root.exists():
        raise SystemExit(f"codex sessions directory not found: {sessions_root}")

    matches = sorted(
        sessions_root.rglob(f"rollout-*{thread_id}.jsonl"),
        key=lambda p: p.stat().st_mtime,
        reverse=True,
    )
    if not matches:
        raise SystemExit(f"no rollout file found for thread_id={thread_id}")
    return matches[0]


def iter_rollout_user_messages(session_path: Path):
    with session_path.open("r", encoding="utf-8") as fh:
        for line in fh:
            obj = json.loads(line)
            if obj.get("type") != "response_item":
                continue
            payload = obj.get("payload", {})
            if payload.get("type") != "message" or payload.get("role") != "user":
                continue
            content = payload.get("content", [])
            if isinstance(content, list):
                yield content


def extract_hint_name(text: str) -> Optional[str]:
    match = IMAGE_NAME_RE.search(text)
    if not match:
        return None
    return match.group("name").strip() or None


def split_data_url(value: str) -> tuple[str, bytes]:
    match = DATA_URL_RE.match(value)
    if not match:
        raise SystemExit("unsupported attachment payload: expected data URL")

    mime_type = match.group("mime").strip() or "application/octet-stream"
    raw = base64.b64decode(match.group("data"))
    return mime_type, raw


def guess_extension(mime_type: str) -> str:
    if mime_type == "image/jpeg":
        return ".jpg"
    ext = mimetypes.guess_extension(mime_type, strict=False)
    if ext == ".jpe":
        return ".jpg"
    return ext or ""


def sanitize_name(name: str, fallback_stem: str, mime_type: str) -> str:
    ext = guess_extension(mime_type)
    raw = name.strip() if name else fallback_stem
    if not Path(raw).suffix and ext:
        raw = f"{raw}{ext}"

    safe = re.sub(r"[^A-Za-z0-9._-]+", "-", raw).strip(".-")
    if not safe:
        safe = fallback_stem
        if ext:
            safe = f"{safe}{ext}"

    suffix = Path(safe).suffix
    if not suffix and ext:
        safe = f"{safe}{ext}"
    return safe


def uniquify_name(name: str, seen_names: set[str]) -> str:
    candidate = name
    stem = Path(name).stem or "attachment"
    suffix = Path(name).suffix
    index = 2
    while candidate in seen_names:
        candidate = f"{stem}-{index}{suffix}"
        index += 1
    seen_names.add(candidate)
    return candidate


def redact_sensitive_text(value: str) -> str:
    redacted = value
    for pattern, replacement in SENSITIVE_REDACTIONS:
        redacted = pattern.sub(replacement, redacted)
    return redacted


def sha256_file(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as fh:
        for chunk in iter(lambda: fh.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


def guess_mime_for_path(path: Path) -> str:
    mime_type, _ = mimetypes.guess_type(str(path))
    return mime_type or ""


def is_image_candidate(path: Path, mime_type: str) -> bool:
    if mime_type.startswith("image/"):
        return True
    return path.suffix.lower() in IMAGE_EXTENSIONS


def is_heic_image(path: Path, mime_type: str) -> bool:
    normalized = mime_type.lower()
    return normalized in {"image/heic", "image/heif"} or path.suffix.lower() in HEIC_EXTENSIONS


def uniquify_stage_name(name: str, out_dir: Path, seen_names: set[str]) -> str:
    candidate = name
    stem = Path(name).stem or "image"
    suffix = Path(name).suffix
    index = 2
    while candidate in seen_names or (out_dir / candidate).exists():
        candidate = f"{stem}-{index}{suffix}"
        index += 1
    seen_names.add(candidate)
    return candidate


def resolve_stage_options(args: list[str]) -> tuple[Path, Optional[Path], bool, list[str]]:
    out_dir = Path(DEFAULT_IMAGE_STAGE_DIR)
    mapping_path = None
    all_images = False
    refs: list[str] = []
    i = 0

    while i < len(args):
        arg = args[i]
        if arg == "--out-dir":
            if i + 1 >= len(args):
                raise SystemExit("--out-dir requires a path")
            out_dir = Path(args[i + 1]).expanduser()
            i += 2
            continue
        if arg.startswith("--out-dir="):
            out_dir = Path(arg.split("=", 1)[1]).expanduser()
            i += 1
            continue
        if arg == "--mapping":
            if i + 1 >= len(args):
                raise SystemExit("--mapping requires a path")
            mapping_path = Path(args[i + 1]).expanduser()
            i += 2
            continue
        if arg.startswith("--mapping="):
            mapping_path = Path(arg.split("=", 1)[1]).expanduser()
            i += 1
            continue
        if arg == "--all":
            all_images = True
            i += 1
            continue
        if arg.startswith("--"):
            raise SystemExit(f"unknown option for stage-images: {arg}")
        refs.append(arg)
        i += 1

    if not all_images and not refs:
        raise SystemExit("stage-images requires --all or at least one path/id/name")

    return out_dir, mapping_path, all_images, refs


def attachment_to_stage_source(item: dict, ref: str) -> dict:
    local_path = attachment_key(item, "local_path")
    if not local_path:
        raise SystemExit(f"attachment has no local_path: {redact_sensitive_text(ref)}")
    path = Path(local_path).expanduser()
    return {
        "kind": "manifest",
        "input": ref,
        "path": path,
        "mime_type": attachment_key(item, "mime_type"),
        "manifest": {
            "id": attachment_key(item, "id"),
            "name": attachment_key(item, "name"),
            "local_path": local_path,
        },
    }


def resolve_stage_sources(manifest_path: Path, all_images: bool, refs: list[str]) -> list[dict]:
    attachments = None
    sources: list[dict] = []

    if all_images:
        attachments = load_attachments(manifest_path)
        for item in attachments:
            local_path = attachment_key(item, "local_path")
            if not local_path:
                continue
            path = Path(local_path).expanduser()
            mime_type = attachment_key(item, "mime_type") or guess_mime_for_path(path)
            if is_image_candidate(path, mime_type):
                sources.append(attachment_to_stage_source(item, attachment_key(item, "id") or attachment_key(item, "name")))

    for ref in refs:
        path = Path(ref).expanduser()
        if path.exists():
            sources.append({"kind": "path", "input": ref, "path": path, "mime_type": guess_mime_for_path(path)})
            continue

        if attachments is None:
            attachments = load_attachments(manifest_path)
        sources.append(attachment_to_stage_source(find_attachment(attachments, ref), ref))

    if not sources:
        raise SystemExit("no image inputs found")
    return sources


def choose_heic_converter(
    which: Callable[[str], Optional[str]] = shutil.which,
    platform: Optional[str] = None,
) -> tuple[str, str]:
    platform = platform or os.environ.get("AGENTS_ATTACHMENTS_PLATFORM") or sys.platform
    if platform == "darwin":
        sips = which("sips")
        if sips:
            return "sips", sips

    magick = which("magick")
    if magick:
        return "imagemagick", magick

    convert = which("convert")
    if convert:
        return "imagemagick-convert", convert

    raise RuntimeError("HEIC normalization requires macOS sips or ImageMagick (magick/convert) on PATH")


def run_heic_normalization(src: Path, dst: Path) -> dict:
    converter, executable = choose_heic_converter()
    if converter == "sips":
        argv = [executable, "-s", "format", "png", str(src), "--out", str(dst)]
    else:
        argv = [executable, str(src), str(dst)]

    completed = subprocess.run(argv, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
    if completed.returncode != 0:
        detail = redact_sensitive_text((completed.stderr or completed.stdout or "").strip())
        label = redact_sensitive_text(src.name)
        raise SystemExit(f"HEIC normalization failed for {label} using {converter}: {detail}")

    return {"from": "heic", "to": "png", "converter": converter}


def staged_name_for_source(src: Path, mime_type: str, index: int, normalize_heic: bool) -> str:
    if normalize_heic:
        raw_name = f"{src.stem}.png"
        output_mime = "image/png"
    else:
        output_mime = mime_type or guess_mime_for_path(src)
        raw_name = src.name

    safe_label = redact_sensitive_text(raw_name)
    safe_name = sanitize_name(safe_label, f"image-{index:03d}", output_mime)
    return f"{index:03d}-{safe_name}"


def stage_one_image(source: dict, out_dir: Path, index: int, seen_names: set[str]) -> dict:
    src = source["path"]
    if not isinstance(src, Path):
        src = Path(str(src))
    if not src.exists():
        raise SystemExit(f"image source not found: {redact_sensitive_text(str(src))}")
    if not src.is_file():
        raise SystemExit(f"image source is not a file: {redact_sensitive_text(str(src))}")

    src = src.resolve()
    mime_type = source.get("mime_type") or guess_mime_for_path(src)
    if not is_image_candidate(src, mime_type):
        raise SystemExit(f"not an image input: {redact_sensitive_text(str(source.get('input', src)))}")

    normalize_heic = is_heic_image(src, mime_type)
    stage_name = staged_name_for_source(src, mime_type, index, normalize_heic)
    stage_name = uniquify_stage_name(stage_name, out_dir, seen_names)
    staged_path = out_dir / stage_name

    if normalize_heic:
        normalization = run_heic_normalization(src, staged_path)
        action = "normalized"
        output_mime = "image/png"
    else:
        shutil.copy2(src, staged_path)
        normalization = None
        action = "copied"
        output_mime = mime_type or guess_mime_for_path(staged_path)

    source_info = {
        "kind": source["kind"],
        "input": redact_sensitive_text(str(source.get("input", ""))),
        "label": redact_sensitive_text(src.name),
        "path": redact_sensitive_text(str(src)),
        "path_sha256": hashlib.sha256(str(src).encode("utf-8")).hexdigest(),
    }
    if source.get("manifest"):
        manifest = source["manifest"]
        source_info["manifest"] = {
            "id": redact_sensitive_text(str(manifest.get("id", ""))),
            "name": redact_sensitive_text(str(manifest.get("name", ""))),
            "local_path": redact_sensitive_text(str(manifest.get("local_path", ""))),
        }

    item = {
        "source": source_info,
        "source_read_only": True,
        "original": {
            "sha256": sha256_file(src),
            "size_bytes": src.stat().st_size,
            "mime_type": mime_type,
        },
        "staged": {
            "path": str(staged_path.resolve()),
            "filename": staged_path.name,
            "sha256": sha256_file(staged_path),
            "size_bytes": staged_path.stat().st_size,
            "mime_type": output_mime,
        },
        "action": action,
    }
    if normalization:
        item["normalization"] = normalization
    return item


def cmd_stage_images(manifest_path: Path, args: list[str]) -> int:
    out_dir, mapping_path, all_images, refs = resolve_stage_options(args)
    if mapping_path is None:
        mapping_path = out_dir / DEFAULT_IMAGE_MAPPING_NAME

    out_dir.mkdir(parents=True, exist_ok=True)
    mapping_path.parent.mkdir(parents=True, exist_ok=True)

    sources = resolve_stage_sources(manifest_path, all_images, refs)
    seen_names: set[str] = set()
    items = [stage_one_image(source, out_dir, index, seen_names) for index, source in enumerate(sources, start=1)]
    payload = {
        "version": 1,
        "out_dir": str(out_dir.resolve()),
        "mapping_path": str(mapping_path.resolve()),
        "items": items,
    }

    with mapping_path.open("w", encoding="utf-8") as fh:
        json.dump(payload, fh, indent=2, ensure_ascii=False)
        fh.write("\n")

    print(json.dumps(payload, indent=2, ensure_ascii=False))
    return 0


def materialize_from_codex_rollout(session_path: Path, out_dir: Path) -> list[dict]:
    out_dir.mkdir(parents=True, exist_ok=True)
    attachments = []
    seen_local_names: set[str] = set()
    seen_display_names: set[str] = set()
    counter = 1

    for content in iter_rollout_user_messages(session_path):
        hint_name = None
        for item in content:
            if not isinstance(item, dict):
                continue

            item_type = item.get("type")
            if item_type == "input_text":
                text = item.get("text", "")
                if isinstance(text, str):
                    hinted = extract_hint_name(text)
                    if hinted:
                        hint_name = hinted
                continue

            if item_type != "input_image":
                continue

            image_url = item.get("image_url")
            if not isinstance(image_url, str) or not image_url.startswith("data:"):
                continue

            mime_type, payload = split_data_url(image_url)
            sha256 = hashlib.sha256(payload).hexdigest()
            fallback_stem = f"attachment-{counter:03d}"
            display_name = sanitize_name(hint_name or "", fallback_stem, mime_type)
            display_name = uniquify_name(display_name, seen_display_names)
            local_name = f"{counter:03d}-{display_name}"
            while local_name in seen_local_names:
                counter += 1
                fallback_stem = f"attachment-{counter:03d}"
                display_name = sanitize_name(hint_name or "", fallback_stem, mime_type)
                display_name = uniquify_name(display_name, seen_display_names)
                local_name = f"{counter:03d}-{display_name}"
            seen_local_names.add(local_name)

            local_path = out_dir / local_name
            local_path.write_bytes(payload)

            attachments.append(
                {
                    "id": f"attachment-{counter:03d}",
                    "name": display_name,
                    "mime_type": mime_type,
                    "size_bytes": len(payload),
                    "sha256": sha256,
                    "local_path": str(local_path.resolve()),
                    "source": "codex-rollout",
                    "metadata": {
                        "session_path": str(session_path),
                    },
                }
            )
            counter += 1
            hint_name = None

    return attachments


def write_manifest(path: Path, attachments: list[dict], session_path: Path) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    payload = {
        "attachments": attachments,
        "source": "codex-rollout",
        "session_path": str(session_path),
    }
    with path.open("w", encoding="utf-8") as fh:
        json.dump(payload, fh, indent=2, ensure_ascii=False)
        fh.write("\n")


def cmd_materialize(manifest_path: Path, args: list[str]) -> int:
    thread_id, session_path, out_dir = resolve_materialize_options(args, manifest_path)
    if session_path is None:
        if not thread_id:
            raise SystemExit("materialize requires --thread-id, --session, or CODEX_THREAD_ID")
        session_path = find_rollout_path(thread_id)

    attachments = materialize_from_codex_rollout(session_path, out_dir)
    if not attachments:
        raise SystemExit(f"no input_image attachments found in {session_path}")

    write_manifest(manifest_path, attachments, session_path)
    print(str(manifest_path.resolve()))
    return 0


def main(argv: list[str]) -> int:
    manifest_path, args = resolve_manifest_path(argv)
    if not args:
        return usage()

    command = args[0]
    if command == "materialize":
        return cmd_materialize(manifest_path, args[1:])
    if command == "stage-images":
        return cmd_stage_images(manifest_path, args[1:])

    attachments = load_attachments(manifest_path)

    if command == "list":
        return cmd_list(attachments)
    if command == "show":
        if len(args) != 2:
            return usage()
        return cmd_show(attachments, args[1])
    if command == "path":
        if len(args) != 2:
            return usage()
        return cmd_path(attachments, args[1])

    return usage()


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
